#include <bits/stdc++.h>
using namespace std;

int main() {
    queue<int> q;
    for (int i = (int)a.size() - 1; i >= 0; i--) {
        q.push(a[i]);
    }
    for (int i = 0; i < (int)a.size(); i++) {
        if (q.empty() || q.front() != a[i]) {
            cout << "The number is not a palindrome\n";
            return 0;
        }
        q.pop();
    }
    cout << "The number is a palindrome\n";
    return 0;
}
