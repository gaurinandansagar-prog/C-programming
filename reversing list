
#include <iostream>
using namespace std;
struct Node {
    int data;
    Node* next;
};
void insert(Node*& head, int val) {
    Node* newNode = new Node{val, NULL};
    if (!head) {
        head = newNode;
        return;
    }
    Node* temp = head;
    while (temp->next)
        temp = temp->next;
    temp->next = newNode;
}
Node* reverseUptoKey(Node* head, int key) {
    Node *prev = NULL, *curr = head, *next = NULL;
    if (!head)
        return NULL;
    while (curr != NULL) {
        next = curr->next;
        curr->next = prev;
        prev = curr;
        if (curr->data == key)
            break;
        curr = next;
    }
    head->next = next;
    return prev;
}
void display(Node* head) {
    while (head) {
        cout << head->data << " -> ";
        head = head->next;
    }
    cout << "NULL\n";
}
int main() {
    Node* head = NULL;
    insert(head,1);
    insert(head,2);
    insert(head,3);
    insert(head,4);
    insert(head,5);
    insert(head,6);
    cout<<"Original List:\n";
    display(head);
    head = reverseUptoKey(head,4);
    cout<<"After Reversing upto key:\n";
    display(head);
    return 0;
}
